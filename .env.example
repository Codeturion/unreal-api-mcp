# Unreal Engine version to serve (e.g. "5.4", "5.5")
# UNREAL_VERSION=5.5

# Path to your Unreal project (auto-detects version from .uproject)
# UNREAL_PROJECT_PATH=F:/Unreal Projects/MyProject

# Override Unreal Engine install path (for ingestion only)
# UNREAL_INSTALL_PATH=C:/Program Files/Epic Games/UE_5.5
