# Unreal Engine version to serve (e.g. "5.4", "5.5", "5.6", "5.7")
# UNREAL_VERSION=5.7

# Path to your Unreal project (auto-detects version from .uproject EngineAssociation field)
# UNREAL_PROJECT_PATH=F:/Unreal Projects/MyProject

# Override Unreal Engine install path (for ingestion only)
# UNREAL_INSTALL_PATH=H:/UE_5.7
